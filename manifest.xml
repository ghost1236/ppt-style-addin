<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="PresentationApp">

  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>PPT Style Addin</ProviderName>
  <DefaultLocale>ko-KR</DefaultLocale>
  <DisplayName DefaultValue="디자인 도구"/>
  <Description DefaultValue="PowerPoint 폰트/컬러/스타일 일괄 적용 Add-in"/>

  <IconUrl DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/"/>

  <AppDomains>
    <AppDomain>https://YOUR_GITHUB_ID.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <!-- 최소 요구사항: PresentationAPI 1.2 (영구 라이선스 2019/2021도 지원) -->
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="PresentationAPI" MinVersion="1.2"/>
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://ghost1236.github.io/ppt-style-addin/taskpane/index.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>

          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- 사이드패널 열기 버튼 -->
                <Control xsi:type="Button" id="TaskPaneButton">
                  <Label resid="TaskPaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskPaneButton.Label"/>
                    <Description resid="TaskPaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

                <!-- 제목 일괄 적용 버튼 -->
                <Control xsi:type="Button" id="ApplyTitleButton">
                  <Label resid="ApplyTitleButton.Label"/>
                  <Supertip>
                    <Title resid="ApplyTitleButton.Label"/>
                    <Description resid="ApplyTitleButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>applyToAllTitles</FunctionName>
                  </Action>
                </Control>

                <!-- 본문 일괄 적용 버튼 -->
                <Control xsi:type="Button" id="ApplyBodyButton">
                  <Label resid="ApplyBodyButton.Label"/>
                  <Supertip>
                    <Title resid="ApplyBodyButton.Label"/>
                    <Description resid="ApplyBodyButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>applyToAllBodies</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/"/>
        <bt:Url id="Commands.Url" DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/commands/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://YOUR_GITHUB_ID.github.io/ppt-style-addin/taskpane/index.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="디자인 도구를 시작합니다"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="디자인 도구"/>
        <bt:String id="TaskPaneButton.Label" DefaultValue="스타일 패널 열기"/>
        <bt:String id="ApplyTitleButton.Label" DefaultValue="제목 일괄 적용"/>
        <bt:String id="ApplyBodyButton.Label" DefaultValue="본문 일괄 적용"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="폰트, 색상, 크기를 일괄 적용하는 PowerPoint 디자인 도구입니다."/>
        <bt:String id="TaskPaneButton.Tooltip" DefaultValue="스타일 편집 패널을 엽니다"/>
        <bt:String id="ApplyTitleButton.Tooltip" DefaultValue="모든 슬라이드 제목에 현재 프리셋을 적용합니다"/>
        <bt:String id="ApplyBodyButton.Tooltip" DefaultValue="모든 슬라이드 본문에 현재 프리셋을 적용합니다"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
